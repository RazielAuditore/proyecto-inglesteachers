# ─── Variables de entorno — api-reservas ─────────────────────────────────────
#
# Copiá este archivo como ".env" y completá los valores reales.
# El archivo ".env" NUNCA debe subirse a git (está en .gitignore).
# En Render estas variables se cargan desde el panel web, no desde un archivo.
#
# Cómo obtener los valores de Supabase:
#   1. Entrá a https://supabase.com y abrí tu proyecto
#   2. Andá a Settings → API
#   3. Copiá "Project URL" y "service_role" secret key
# ─────────────────────────────────────────────────────────────────────────────

# URL de tu proyecto Supabase
# Ejemplo: https://abcdefghijkl.supabase.co
SUPABASE_URL=

# Clave secreta "service_role" de Supabase.
# Usamos service_role (y no anon) porque el servidor necesita
# acceso completo sin restricciones de Row Level Security.
# IMPORTANTE: esta clave va solo en el backend, nunca en el frontend.
SUPABASE_KEY=

# Puerto donde escucha el servidor Express.
# Render lo asigna automáticamente — no hace falta configurarlo en producción.
# En desarrollo local se usa 8080 si no está definido.
PORT=8080

# Orígenes permitidos para CORS (de dónde puede llamar el frontend).
# En desarrollo no hace falta configurar esto.
# En producción poné la URL de tu frontend en Render:
# Ejemplo: https://mi-frontend.onrender.com
CORS_ORIGIN=
